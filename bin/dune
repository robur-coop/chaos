(executable
 (name main)
 (modules main)
 (modes native)
 (link_flags :standard -cclib "-z solo5-abi=hvt")
 (libraries re mkernel mnet mnet-cli mirage-crypto-rng-mkernel mkernel-memtrace cmdliner chaos chaos.tscclock logs.fmt logs.cli fmt.cli)
 (foreign_stubs
  (language c)
  (names manifest)))

(executable
 (name trace)
 (enabled_if (= %{context_name} "default"))
 (libraries fmt cmdliner))

(rule
 (targets manifest.c)
 (enabled_if
  (= %{context_name} "default"))
 (action
  (write-file manifest.c "")))

(rule
 (targets manifest.c)
 (deps manifest.json)
 (enabled_if
  (= %{context_name} "solo5"))
 (action
  (run solo5-elftool gen-manifest manifest.json manifest.c)))

(rule
 (targets manifest.json)
 (enabled_if
  (= %{context_name} "solo5"))
 (action
  (with-stdout-to
   manifest.json
   (run %{exe:main.exe} --ipv4=0.0.0.0/24 --metrics=metrics))))
